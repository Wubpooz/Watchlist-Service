{
  "name": "projet-aos-app5",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "bun --filter backend dev",
    "dev:frontend": "bun --filter frontend dev",
    "dev:all": "concurrently \"bun --filter backend dev\" \"bun --filter frontend dev\"",
    "test": "bun --filter backend test",
    "mcp:stdio": "bun --filter backend mcp:stdio",
    "mcp:test": "bun --filter backend mcp:test",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "bun --filter backend build",
    "build:frontend": "bun --filter frontend build",
    "prisma:generate": "bun --filter backend prisma:generate",
    "prisma:migrate": "bun --filter backend prisma:migrate",
    "prisma:seed": "bun --filter backend prisma:seed",
    "prisma:studio": "bun --filter backend prisma:studio",
    "openapi:generate": "bun --filter backend openapi:generate",
    "setup:db": "docker run --name aos-postgres -e POSTGRES_USER=johndoe -e POSTGRES_PASSWORD=randompassword -e POSTGRES_DB=mydb -p 5432:5432 -d postgres:16 || docker start aos-postgres",
    "setup:env": "powershell -Command \"(Get-Content backend\\.env) -replace '^DATABASE_URL=.*', 'DATABASE_URL=postgresql://johndoe:randompassword@localhost:5432/mydb' | Set-Content backend\\.env\"",
    "dev:stack": "bun run setup:db && timeout /t 2 /nobreak && bun run setup:env && bun install && bun run prisma:generate && bun run prisma:seed && bun run dev",
    "postinstall": "bun --filter backend prisma:generate"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3"
  }
}
