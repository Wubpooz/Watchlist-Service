{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot run src/index.ts",
    "test": "bun test",
    "mcp:dev": "bun --hot run src/index.ts",
    "mcp:stdio": "bun run src/mcp/stdio.ts",
    "mcp:test": "bun test src/mcp/**/*.test.ts",
    "build": "bun run build:tsc",
    "build:tsc": "tsc --project tsconfig.json",
    "start": "bun run build/index.js",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate": "bunx --bun prisma migrate dev",
    "prisma:seed": "bun run src/db/seed.ts",
    "prisma:studio": "bunx --bun prisma studio",
    "openapi:generate": "bun run scripts/generate-openapi.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/pg": "^8.18.0",
    "bun-types": "^1.3.10",
    "prisma": "^7.4.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.13",
    "@hono/node-server": "^1.19.11",
    "@hono/standard-validator": "^0.2.2",
    "@hono/swagger-ui": "^0.6.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/node": "^25.4.0",
    "better-auth": "^1.5.4",
    "env": "^0.0.2",
    "hono": "^4.12.22",
    "hono-openapi": "^1.3.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  }
}
