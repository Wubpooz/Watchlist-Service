{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot run src/server.ts",
    "test": "bun test",
    "mcp:dev": "bun --hot run src/server.ts",
    "mcp:stdio": "bun run src/mcp/stdio.ts",
    "mcp:test": "bun test src/mcp/**/*.test.ts",
    "build": "bun run build:tsc",
    "build:tsc": "tsc --project tsconfig.json",
    "start": "bun run build/server.js",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate": "bunx --bun prisma migrate dev",
    "prisma:seed": "bun run src/db/seed.ts",
    "prisma:studio": "bunx --bun prisma studio",
    "openapi:generate": "bun run scripts/generate-openapi.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.14",
    "prisma": "^7.8.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.13",
    "@hono/node-server": "^2.0.4",
    "@hono/standard-validator": "^0.2.2",
    "@hono/swagger-ui": "^0.6.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.9.1",
    "better-auth": "^1.6.13",
    "env": "^0.0.2",
    "hono": "^4.12.23",
    "hono-openapi": "^1.3.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  }
}
